{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "BestShopConnectionString": "Data Source=.;Initial Catalog=BestShopDb;Integrated Security=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "PasswordPolicy": {
    "MinLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSpecialCharacter": false
  }

}
