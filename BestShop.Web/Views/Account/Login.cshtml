@model LoginViewModel
@{
    ViewData["Title"] = PropertyDictionary.Login;
}
@section Header {
    <style>
        input[type="email"] {
            direction: ltr;
            text-align: left;
        }

            input[type="email"]::placeholder {
                direction: rtl;
                text-align: right;
            }
    </style>
}
<div class="auth-container">
    <div class="auth-title mb-3">@PropertyDictionary.Register</div>
    <div class="auth-box ui-box">
        <form asp-controller="Account" asp-action="Login" class="auth-form">
            @Html.HiddenFor(a => a.ReturnUrl)
            <div class="form-element-row mb-2">
                <input asp-for="UserNameOrEmail" class="form-control" placeholder="@PropertyDictionary.UserNameOrEmail">
            </div>

            <div class="form-element-row mb-2">
                <input asp-for="Password" class="form-control" placeholder="@PropertyDictionary.Password">
            </div>

            <div class="row mb-2">
                <div class="col-1 pt-1">
                    <input asp-for="RememberMe" class="form-check">
                </div>
                <div class="col-10">
                    <span>@PropertyDictionary.RememberMe</span>

                </div>
            </div>


            <div class="form-element-row mb-3">
                <button class="btn btn-primary">@PropertyDictionary.Login</button>
            </div>
            <div class="form-element-row ">
                <div class="mb-5">
                    <a asp-controller="Account" asp-action="ForgotPassword">
                        @PropertyDictionary.ForgotPassword
                    </a>
                </div>
                <div class="mb-5">
                    با ورود در سایت شما <a href="#" class="link">
                        شرایط و
                        قوانین
                    </a> استفاده
                    از تمام سرویس های
                    سایت و <a href="#" class="link">قوانین حریم خصوصی</a> آن را می‌پذیرید.
                </div>
                <div asp-validation-summary="All" class="text-danger"></div>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}